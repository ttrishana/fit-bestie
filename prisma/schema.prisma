// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Goal {
  FAT_LOSS
  MUSCLE_GAIN
  BODY_RECOMP
  MAINTENANCE
}

enum SplitType {
  PPL
  UPPER_LOWER
  FULL_BODY
  CUSTOM
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  refreshTokenHash String?  @map("refresh_token_hash") 
  name          String
  bodyWeightKg  Float?   @map("body_weight_kg")
  goal          Goal?
  daysPerWeek   Int?     @map("days_per_week")
  dailyCalories Int?     @map("daily_calories")
  dailyProteinG Int?     @map("daily_protein_g")
  createdAt     DateTime @default(now()) @map("created_at")

  splits          Split[]
  workoutSessions WorkoutSession[]

  @@map("users")
}

model Split {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  name      String
  type      SplitType
  isActive  Boolean   @default(false) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  splitDays SplitDay[]

  @@map("splits")
}

model SplitDay {
  id        String @id @default(uuid()) @db.Uuid
  splitId   String @map("split_id") @db.Uuid
  dayNumber Int    @map("day_number")
  label     String

  split             Split              @relation(fields: [splitId], references: [id], onDelete: Cascade)
  splitDayExercises SplitDayExercise[]
  workoutSessions   WorkoutSession[]

  @@map("split_days")
}

model Exercise {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  muscleGroups String[]   @map("muscle_groups")
  difficulty   Difficulty
  defaultSets  Int        @map("default_sets")
  defaultReps  String     @map("default_reps")
  demoUrl      String?    @map("demo_url")
  isSystem     Boolean    @default(true) @map("is_system")

  splitDayExercises SplitDayExercise[]
  setLogs           SetLog[]

  @@map("exercises")
}

model SplitDayExercise {
  id         String @id @default(uuid()) @db.Uuid
  splitDayId String @map("split_day_id") @db.Uuid
  exerciseId String @map("exercise_id") @db.Uuid
  orderIndex Int    @map("order_index")
  sets       Int
  reps       String

  splitDay SplitDay @relation(fields: [splitDayId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@map("split_day_exercises")
}

model WorkoutSession {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  splitDayId  String    @map("split_day_id") @db.Uuid
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  splitDay SplitDay @relation(fields: [splitDayId], references: [id], onDelete: Restrict)
  setLogs  SetLog[]

  @@map("workout_sessions")
}

model SetLog {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  exerciseId String   @map("exercise_id") @db.Uuid
  setNumber  Int      @map("set_number")
  weightKg   Float    @map("weight_kg")
  reps       Int
  loggedAt   DateTime @default(now()) @map("logged_at")

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@map("set_logs")
}
